<!--
    Client Specific Rules for holglo
    File: 950000-holglo.xml
    These rules should only match when agent.labels.group is holgo.
-->

<group name="holglo,">

  <rule id="950000" level="1">
    <if_group>sysmon_event1</if_group>
    <field name="agent.labels.group" type="pcre2">holgo</field>
    <description>Holglo - Suppress Sysmon Event 1 alerts for holgo group</description>
    <options>no_log</options>
  </rule>

  <rule id="950001" level="1">
    <if_group>sysmon_event3</if_group>
    <field name="agent.labels.group" type="pcre2">holgo</field>
    <description>Holglo - Suppress Sysmon Event 3 alerts for holgo group</description>
    <options>no_log</options>
  </rule>

</group>
